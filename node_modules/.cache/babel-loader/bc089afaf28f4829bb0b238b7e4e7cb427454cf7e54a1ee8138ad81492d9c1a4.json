ointer;\n    height: 50px;\n    justify-self: flex-end;\n    margin-top: 120%;\n    width: 50px;\n}\n\n#musicas-autorais {\n    height: 100%;\n    width: 100%;\n    overflow: auto;\n}\n\n#nasa {\n    display: flex;\n    align-items: flex-start;\n    height: 100%;\n    margin-top: 15%;\n    width: 100%;\n}\n\n#panel {\n    align-items: flex-start;\n    background-color: #3b5005;\n    border: solid 5px #2e3f05;\n    border-radius: 5px;\n    height: 80%;\n    justify-content: center;\n    margin-left: 5%;\n    margin-right: -15%;\n    width: 50%;\n}\n\n#rickandmorty {\n    align-items: flex-start;\n    display: flex;\n    justify-content: flex-start;\n    height: 100%;\n    width: 100%;\n}\n\n#rm {\n    font-size: 8px;\n}\n\n#sidebar {\n    border: solid 1px #3b5005;\n    height: 95%;\n    margin-left: 5%;\n    opacity: 0.8;\n}\n\n.buttons {\n    align-items: flex-start;\n    display: flex;\n    flex-direction: column;\n    margin-left: -15%;\n    margin-top: -40%;\n\n}\n\n.buttons a {\n    background-color: var(--bege-bg);\n    border: solid 2px #EAD05E;\n    border-radius: 5px;\n    color: var(--branco);\n    font-size: 10px;\n    font-weight: bold;\n    height: 18px;\n    margin-top: 30%;\n    margin-left: -10%;\n    text-align: center;\n    width: 84px;\n}\n\n.buttons a:hover {\n    animation: jello 1s;\n}\n\n\n\n@media (min-width: 950px) {\n\n    #display {\n        border-radius: 15px;\n        height: 822px;\n        width: 994px;\n    }\n\n    #panel {\n        border-radius: 15px;\n        height: 730px;\n        margin-left: 14%;\n        width: 640px;\n    }\n\n\n    #sidebar {\n        margin-left: 5%;\n        margin-right: -7%;\n\n    }\n\n    #musicas {\n        height: 80px;\n        margin-left: 5%;\n        width: 80px;\n    }\n\n    #rm {\n        font-size: 0.8rem;\n        margin-bottom: 150%;\n        text-align: center;\n    }\n\n    .buttons {\n        margin-top: -20%;\n    }\n\n    .buttons a {\n        font-size: 0.8rem;\n        height: 25px