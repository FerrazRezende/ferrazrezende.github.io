{"ast":null,"code":"export default {\n  name: 'headerPage',\n  data() {\n    return {\n      ativarMenu: false\n    };\n  },\n  methods: {\n    abrirMenu: function () {\n      this.ativarMenu = !this.ativarMenu;\n      this.$emit('headerAtivado', this.ativarMenu);\n    }\n  }\n};","map":{"version":3,"names":["name","data","ativarMenu","methods","abrirMenu","$emit"],"sources":["/home/matheus/Projetos/ferrazrezende.github.io/src/components/headerPage.vue"],"sourcesContent":["<script>\n\nexport default {\n    name: 'headerPage',\n    data () {\n        return {\n            ativarMenu: false\n        }\n    },\n    methods: {\n        abrirMenu: function () {\n            this.ativarMenu = !this.ativarMenu\n            this.$emit('headerAtivado', this.ativarMenu)\n        }\n    }\n}\n\n</script>\n\n<template>\n\n    <header>\n        <nav class=\"container\">\n            <a><img src=\"/img/Logo.svg\" id=\"logo\" alt=\"Logo\"></a>\n            <a v-on:click=\"abrirMenu\"><img src=\"/img/menu-bar.svg\" id=\"menu-bar\"></a>\n            \n            <div v-if=\"ativarMenu\" id=\"overlay\" v-on:click=\"abrirMenu\" class=\"animate__animated animate__fadeInLeft\"></div>\n            \n            <div id=\"items\" :class=\"{ativar:ativarMenu}\" class=\"animate__animated animate__fadeInRight\">\n                <ul>\n                    <li><a href=\"#sobre\">Sobre</a></li>\n                    <li><a href=\"#projetos\">Projetos</a></li>\n                    <li><a href=\"#api\">APIs</a></li>\n                    <li id=\"curriculo\"><a>Curriculo</a></li>\n                </ul>\n            </div>\n            </nav>\n        </header>\n\n</template>\n\n\n<style scoped>\n\n@import '@/style/global.css';\n@import 'animate.css';\n@import '@/style/animations.css';\n\nheader {\n    height: 105px;\n    width: 100%;\n}\n\nnav {\n    align-items: center;\n    display: flex;\n    justify-content: space-between;\n}\n\nul {\n    list-style: none;\n}\n\nul li a {\n    color: var(--branco);\n    font-size: 1.5rem;\n}\n\nul li {\n    margin: 50px 0;\n}\n\n#curriculo {\n    border: solid 4px var(--amarelo-borda);\n    border-radius: 25px;\n    margin-left: 2%;\n    width: 105%;\n\n}\n\n#items {\n    align-items: center;\n    background-color: var(--bege-bg);\n    display: none;\n    flex-direction: column;\n    height: 100vh;\n    justify-content: flex-start;\n    position: fixed;\n    right: 0;\n    top: 0;\n    transition: 1s;\n    width: 60%;\n    z-index: 60;\n}\n\n#items.ativar{\n    display: flex;\n\n\n}\n\n#logo {\n    height: 75px;\n    width: 109px;\n}\n\n#overlay {\n    animation: overlayInLeft 1s;\n    background-color: black;\n    height: 100vh;\n    left: 0;\n    opacity: 0.5;\n    position: fixed;\n    top: 0;\n    width:40%;\n    z-index: 60;\n}\n\n@media (min-width: 950px) {\n    \n    #menu-bar, #overlay {\n        display: none;\n    }\n\n    #logo {\n        height: 75px;\n        width: 109px;\n    }\n\n    #items {\n        display: flex;\n        height: auto;\n        position: static;\n        width: auto;\n        baclground-color: none;\n    }\n\n    ul {\n        align-items: center;\n        display: flex;\n        margin-left: 287px;\n    }\n\n    ul li {\n        margin-right: 20%;\n        margin-top: -30%;\n    }\n\n    ul li a {\n        font-size: 1rem;\n    }\n\n    header {\n        display: flex;\n        align-items: center;\n        flex-direction: column;\n        height: 105px;\n    }\n\n    \n    nav {\n        display: inline;\n        justify-content: space-between;\n        width: 768px;\n    }\n}\n\n@media (min-width: 1490px) {\n    #menu-bar, #overlay {\n        display: none;\n    }\n\n    #logo {\n        height: 75px;\n        width: 109px;\n    }\n\n    #items {\n        display: flex;\n        height: auto;\n        position: static;\n        width: auto;\n    }\n\n    ul {\n        align-items: center;\n        display: flex;\n        margin-left: 287px;\n    }\n\n    ul li {\n        margin-right: 20%;\n        margin-top: -30%;\n    }\n\n    ul li a {\n        font-size: 1rem;\n    }\n\n    header {\n        align-items: center;\n        display: flex;\n        height: 105px;\n        flex-direction: column;\n    }\n\n    nav {\n        display: inline;\n        justify-content: space-between;\n        width: 768px;\n    }\n}\n\n</style>\n"],"mappings":"AAEA,eAAe;EACXA,IAAI,EAAE,YAAY;EAClBC,IAAGA,CAAA,EAAK;IACJ,OAAO;MACHC,UAAU,EAAE;IAChB;EACJ,CAAC;EACDC,OAAO,EAAE;IACLC,SAAS,EAAE,SAAAA,CAAA,EAAY;MACnB,IAAI,CAACF,UAAS,GAAI,CAAC,IAAI,CAACA,UAAS;MACjC,IAAI,CAACG,KAAK,CAAC,eAAe,EAAE,IAAI,CAACH,UAAU;IAC/C;EACJ;AACJ"},"metadata":{},"sourceType":"module","externalDependencies":[]}