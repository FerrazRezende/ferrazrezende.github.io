{"ast":null,"code":"import nasa from '@/services/nasa';\nexport default {\n  name: 'apiNasa',\n  data() {\n    return {\n      imagemExibida: false,\n      aberto: false,\n      linkImagem: '',\n      tituloImagem: '',\n      abrirOuFechar: 'Abrir',\n      mostrarTexto: false,\n      descricaoImagem: \"\"\n    };\n  },\n  methods: {\n    exibirImagem: function () {\n      this.imagemExibida = !this.imagemExibida;\n      this.aberto = !this.aberto;\n      if (this.aberto === true) {\n        this.abrirOuFechar = 'Fechar';\n      }\n      if (this.aberto === false) {\n        this.abrirOuFechar = 'Abrir';\n      }\n    },\n    abrirTexto: function () {\n      this.mostrarTexto = !this.mostrarTexto;\n    }\n  },\n  props: {\n    exibirNasa: Boolean\n  },\n  mounted() {\n    nasa.get().then(resp => {\n      this.linkImagem = resp.data.url;\n      this.tituloImagem = resp.data.title;\n      this.descricaoImagem = resp.data.explanation;\n      console.log(resp.data);\n    });\n  }\n};","map":{"version":3,"names":["nasa","name","data","imagemExibida","aberto","linkImagem","tituloImagem","abrirOuFechar","mostrarTexto","descricaoImagem","methods","exibirImagem","abrirTexto","props","exibirNasa","Boolean","mounted","get","then","resp","url","title","explanation","console","log"],"sources":["/home/matheus/Projetos/ferrazrezende.github.io/src/components/apiNasa.vue"],"sourcesContent":["<script>\n\nimport nasa from '@/services/nasa'\n\n    export default {\n        name: 'apiNasa',\n        data() {\n            return {            \n                imagemExibida: false,\n                aberto: false,\n                linkImagem: '',\n                tituloImagem: '',\n                abrirOuFechar: 'Abrir',\n                mostrarTexto: false,\n                descricaoImagem: \"\",\n            }\n        },\n        methods: {\n            exibirImagem: function () {\n                this.imagemExibida = !this.imagemExibida\n                \n                this.aberto = !this.aberto\n\n                if (this.aberto === true) {\n                    this.abrirOuFechar = 'Fechar'\n                }\n\n                if (this.aberto === false) {\n                    this.abrirOuFechar = 'Abrir'\n                }\n                \n            },\n            abrirTexto: function () {\n                this.mostrarTexto = !this.mostrarTexto\n        }\n        },\n        props: {\n            exibirNasa: Boolean\n        },\n        mounted() {\n            nasa.get()\n            .then(resp => {\n                this.linkImagem = resp.data.url\n                this.tituloImagem = resp.data.title\n                this.descricaoImagem = resp.data.explanation\n                console.log(resp.data)\n            })\n        }\n    }\n</script>\n\n<template>\n    <div class=\"aninated__animated animate__bounceIn\" v-if=\"exibirNasa\">\n        <a @click=\"exibirImagem()\">{{ abrirOuFechar }} a imagem do dia</a>\n        <div v-if=\"imagemExibida\" id=\"api-cont\" class=\"animate__animated animate__jackInTheBox\">\n            <h1>{{ tituloImagem }}</h1>\n            <div id=\"foto-cont\">\n                <img :src=\"linkImagem\" >\n                <p v-if=\"mostrarTexto\" @click=\"abrirTexto\" id=\"fechar-texto\">x</p>\n                <div @click=\"abrirTexto\" id=\"info-foto\"><ion-icon name=\"help-circle-outline\"></ion-icon>\n                </div>\n\n                <p id=\"texto-descritivo\" v-if=\"mostrarTexto\">{{ descricaoImagem }}</p>\n            </div>\n        </div>\n    </div>\n</template>\n\n<style scoped>\n@import '@/style/global.css';\n@import 'animate.css';\n@import '@/style/animations.css';\n\na {\n    align-self: center;\n    background-color: var(--verde-claro);\n    border: solid 2px var(--verde-escuro);\n    border-radius: 5px;\n    color: var(--branco); \n    cursor: pointer;\n    font-size: 0.7rem;\n    font-weight: bold;\n    margin-top: -10%;\n    margin-bottom: 20%;\n    padding: 2%;\n    text-align: center;\n    width: 110%;\n    white-space: nowrap;\n}\n\n\ndiv {\n    align-items: center;\n    display: flex;\n    flex-direction: column;\n    justify-content: flex-end;\n    }\n\n\nh1 {\n    color: var(--branco);\n    font-size: 0.6rem;\n    margin-bottom: 10%;\n    white-space: nowrap;\n}\n\n\nimg{\n    height: 128px;\n    width: 128px;\n}\n\n#api-cont {\n    display: flex;\n    flex-direction: column;\n    height: 100%;  \n    margin-top: 0;\n    width: 110px;\n}\n\n#texto-descritivo {\n    position: absolute;\n    background-color: black;\n    color: var(--branco);\n    font-size: .7rem;\n    overflow: auto;\n    height: 80%;\n    width: 120%;\n    border-radius: 8px;\n    padding: 4px;\n    opacity: 0.8;\n}\n\n#fechar-texto {\n    font-size: 1rem;\n    color: var(--branco);\n    position: absolute;\n    z-index: 100;\n    top: 25px;\n    right: 130px;\n    cursor: pointer;\n}\n\n\n#foto-cont {\n    border: solid 5px var(--verde-claro);\n    border-radius: 5px;\n    height: auto;\n    margin-top: 0%;\n    width: auto;\n}\n\n#info-foto {\n    position: absolute;\n    right: 0%;\n    cursor: pointer;\n\n}\n\n\n@media (min-width: 950px) {\n\n    #texto-descritivo {\n        width: 328px;\n        font-size: 1rem;\n    }\n\n    #fechar-texto {\n        top: 80px;\n        right: 240px;\n        position: absolute;\n    }\n\n    img {\n        width:332px;\n        height: 299px;\n    }\n\n    a {\n        font-size: 1.5rem;\n        width: 420px;\n        margin-bottom: 7%;\n    }\n\n    h1 {\n        font-size: 1.5rem;\n    }\n\n    #info-foto {\n        left: 202px;\n\n    }\n\n}\n\n@media (min-width: 1490px) {\n\n    a {\n        box-shadow: rgba(0, 0, 0, 0.3) 0px 19px 38px, rgba(0, 0, 0, 0.22) 0px 15px 12px;\n        font-size: 2rem;\n        margin: -10% 0 0 0;\n        text-align: center;\n        width: 556px;\n    }\n\n    a:hover {\n        cursor: pointer;\n    }\n\n    h1 {\n        color: var(--branco);\n    }\n\n    img{\n        height: 445px;\n        width: 510px;       \n    }\n\n    #api-cont {\n        max-height: 100%;  \n        margin-top: 10%;\n        width: 100%;\n    }\n\n    #foto-cont {\n        border: solid 10px var(--verde-claro);\n        border-radius: 15px;\n        height: 100%;\n        margin-top: 0%;\n        width: 100%;\n    }\n}\n\n\n</style>\n"],"mappings":"AAEA,OAAOA,IAAG,MAAO,iBAAgB;AAE7B,eAAe;EACXC,IAAI,EAAE,SAAS;EACfC,IAAIA,CAAA,EAAG;IACH,OAAO;MACHC,aAAa,EAAE,KAAK;MACpBC,MAAM,EAAE,KAAK;MACbC,UAAU,EAAE,EAAE;MACdC,YAAY,EAAE,EAAE;MAChBC,aAAa,EAAE,OAAO;MACtBC,YAAY,EAAE,KAAK;MACnBC,eAAe,EAAE;IACrB;EACJ,CAAC;EACDC,OAAO,EAAE;IACLC,YAAY,EAAE,SAAAA,CAAA,EAAY;MACtB,IAAI,CAACR,aAAY,GAAI,CAAC,IAAI,CAACA,aAAY;MAEvC,IAAI,CAACC,MAAK,GAAI,CAAC,IAAI,CAACA,MAAK;MAEzB,IAAI,IAAI,CAACA,MAAK,KAAM,IAAI,EAAE;QACtB,IAAI,CAACG,aAAY,GAAI,QAAO;MAChC;MAEA,IAAI,IAAI,CAACH,MAAK,KAAM,KAAK,EAAE;QACvB,IAAI,CAACG,aAAY,GAAI,OAAM;MAC/B;IAEJ,CAAC;IACDK,UAAU,EAAE,SAAAA,CAAA,EAAY;MACpB,IAAI,CAACJ,YAAW,GAAI,CAAC,IAAI,CAACA,YAAW;IAC7C;EACA,CAAC;EACDK,KAAK,EAAE;IACHC,UAAU,EAAEC;EAChB,CAAC;EACDC,OAAOA,CAAA,EAAG;IACNhB,IAAI,CAACiB,GAAG,CAAC,EACRC,IAAI,CAACC,IAAG,IAAK;MACV,IAAI,CAACd,UAAS,GAAIc,IAAI,CAACjB,IAAI,CAACkB,GAAE;MAC9B,IAAI,CAACd,YAAW,GAAIa,IAAI,CAACjB,IAAI,CAACmB,KAAI;MAClC,IAAI,CAACZ,eAAc,GAAIU,IAAI,CAACjB,IAAI,CAACoB,WAAU;MAC3CC,OAAO,CAACC,GAAG,CAACL,IAAI,CAACjB,IAAI;IACzB,CAAC;EACL;AACJ"},"metadata":{},"sourceType":"module","externalDependencies":[]}