{"ast":null,"code":"import headerPage from '@/components/headerPage.vue';\nimport infoCards from '@/components/infoCards.vue';\nimport SobreMim from '@/views/SobreMim.vue';\nimport MeusProjetos from '@/views/MeusProjetos.vue';\nimport ConsumindoApis from '@/views/ConsumindoApis.vue';\nimport FooterFinal from '@/views/FooterFinal.vue';\nexport default {\n  name: 'App',\n  components: {\n    headerPage,\n    SobreMim,\n    infoCards,\n    MeusProjetos,\n    ConsumindoApis,\n    FooterFinal\n  },\n  data() {\n    return {\n      exibirBotoes: false,\n      botoesVisiveis: true\n    };\n  },\n  methods: {\n    mostrarBotoes: function () {\n      this.exibirBotoes = !this.exibirBotoes;\n    },\n    esconderBotoes: function () {\n      this.botoesVisiveis = window.scrollY < 300;\n    }\n  },\n  mounted() {\n    window.addEventListener('scroll', this.esconderBotoes);\n  },\n  beforeDestroy() {\n    window.removeEventListener('scroll', this.esconderBotoes);\n  }\n};","map":{"version":3,"names":["headerPage","infoCards","SobreMim","MeusProjetos","ConsumindoApis","FooterFinal","name","components","data","exibirBotoes","botoesVisiveis","methods","mostrarBotoes","esconderBotoes","window","scrollY","mounted","addEventListener","beforeDestroy","removeEventListener"],"sources":["/home/matheus/Projetos/ferrazrezende.github.io/src/App.vue"],"sourcesContent":["<script>\nimport headerPage from '@/components/headerPage.vue';\nimport infoCards from '@/components/infoCards.vue';\nimport SobreMim from '@/views/SobreMim.vue';\nimport MeusProjetos from '@/views/MeusProjetos.vue';\nimport ConsumindoApis from '@/views/ConsumindoApis.vue';\nimport FooterFinal from '@/views/FooterFinal.vue';\n\nexport default {\n\n  name: 'App',\n  components: {\n    headerPage,\n    SobreMim,\n    infoCards,\n    MeusProjetos,\n    ConsumindoApis,\n    FooterFinal\n  },\n  data () {\n    return {\n      exibirBotoes: false,\n      botoesVisiveis: true,\n    }\n  },\n  methods: {\n    mostrarBotoes: function () {\n      this.exibirBotoes = !this.exibirBotoes\n    },\n    esconderBotoes: function () {\n        this.botoesVisiveis = window.scrollY < 300;\n    }\n  },\n  mounted () {\n    window.addEventListener('scroll', this.esconderBotoes);\n  },\n  beforeDestroy () {\n    window.removeEventListener('scroll', this.esconderBotoes);\n  }\n}\n</script>\n\n<template>\n\n  <div>\n    <a id=\"menu-button\" @click=\"mostrarBotoes\" v-show=\"botoesVisiveis\">\n    </a>\n    <div v-if=\"exibirBotoes\">\n      <a id=\"github-button\" href=\"https://github.com/FerrazRezende\" target=\"_blank\" class=\"animate__animated animate__zoomInUp\">\n      </a>\n      <a id=\"soundcloud-button\" href=\"https://linktr.ee/cognizantrance\" class=\"animate__animated animate__zoomInUp\" >\n      </a>\n<!--      <a id=\"curriculo-button\" href=\"https://drive.google.com/file/d/1FusTMfaIOmmF1hozXTPBh3yNz94NslNy/view?usp=sharing\" class=\"animate__animated animate__zoomInUp\" target=\"_blank\">\n      </a> -->\n  </div>\n\n    <headerPage />\n    <SobreMim />\n    <infoCards class=\"bg-1\"/>\n    <MeusProjetos class=\"bg-reverse\" />\n    <ConsumindoApis />\n    <FooterFinal />\n\n  </div>\n</template>\n\n\n\n<style>\n@import \"@/style/global.css\";\n@import 'animate.css';\n\n.bg-1 {\n  background-image: url(../public/img/bg-dktp.svg);\n  background-size: 100%;\n  background-repeat: no-repeat;\n  width: 100%;\n}\n\n.bg-reverse {\n  background-image: url(../public/img/image.png);\n  background-size: 100%;\n  background-repeat: no-repeat;\n  width: 100%;\n\n}\n\n#curriculo-button {\n  animation-delay: 1s;\n  background-image: url(../public/img/docpng.png);\n  background-position: center;\n  background-repeat: no-repeat;\n  background-size: 100%;\n  border-radius: 50%;\n  bottom: 160px;\n  cursor: pointer;\n  height: 45px;\n  margin: 3% 3.5%;\n  position: fixed;\n  width: 45px;\n  z-index: 10;\n}\n\n\n#github-button {\n  background-image: url(../public/img/github.png);\n  background-repeat: no-repeat;\n  background-position: center;\n  background-size: 100%;\n  border-radius: 50%;\n  bottom: 70px;\n  cursor: pointer;\n  height: 45px;\n  margin: 3% 3.5%;\n  position: fixed;\n  width: 45px;\n  z-index: 10;\n}\n\n#menu-button {\n  background-image: url(../public/img/botao.png);\n  background-position: center;\n  background-repeat: no-repeat;\n  background-size: 100%;\n  border-radius: 50%;\n  bottom: 0;\n  cursor: pointer;\n  height: 60px;\n  margin: 5% 0 5% 2%; \n  position: fixed;\n  width: 60px;\n  z-index: 10;\n}\n\n\n#soundcloud-button {\n  animation-delay: 0.5s;\n  background-image: url(../public/img/soundcloud.png);\n  background-repeat: no-repeat;\n  background-position: center;\n  background-size: 100%;\n  border-radius: 50%;\n  bottom: 115px;\n  cursor: pointer;\n  height: 45px;\n  margin: 3% 3.5%;\n  position: fixed;\n  width: 45px;\n  z-index: 10;\n}\n\n@media (min-width: 950px) {\n\n  .bg-1 {\n    border: 1px solid transparent;\n    background-position: 0% 67%;\n    \n  }\n\n  #curriculo-button {\n    bottom: 190px;\n    left: -11px;\n  }\n\n  #github-button {\n    bottom: 90px;\n    left: -11px;\n  }\n\n  #soundcloud-button {\n    bottom: 140px;\n    left: -11px;\n  }\n}\n\n@media (min-width: 1490px) {\n\n  #curriculo-button {\n    bottom: 220px;\n    left: -30px;\n  }\n\n  #github-button {\n    bottom: 120px;\n    left: -30px;\n  }\n\n  #soundcloud-button {\n    bottom: 170px;\n    left: -30px;\n  }\n}\n\n</style>\n"],"mappings":"AACA,OAAOA,UAAS,MAAO,6BAA6B;AACpD,OAAOC,SAAQ,MAAO,4BAA4B;AAClD,OAAOC,QAAO,MAAO,sBAAsB;AAC3C,OAAOC,YAAW,MAAO,0BAA0B;AACnD,OAAOC,cAAa,MAAO,4BAA4B;AACvD,OAAOC,WAAU,MAAO,yBAAyB;AAEjD,eAAe;EAEbC,IAAI,EAAE,KAAK;EACXC,UAAU,EAAE;IACVP,UAAU;IACVE,QAAQ;IACRD,SAAS;IACTE,YAAY;IACZC,cAAc;IACdC;EACF,CAAC;EACDG,IAAGA,CAAA,EAAK;IACN,OAAO;MACLC,YAAY,EAAE,KAAK;MACnBC,cAAc,EAAE;IAClB;EACF,CAAC;EACDC,OAAO,EAAE;IACPC,aAAa,EAAE,SAAAA,CAAA,EAAY;MACzB,IAAI,CAACH,YAAW,GAAI,CAAC,IAAI,CAACA,YAAW;IACvC,CAAC;IACDI,cAAc,EAAE,SAAAA,CAAA,EAAY;MACxB,IAAI,CAAC