/matheus/Projetos/ferrazrezende.github.io/src/views/MeusProjetos.vue"],"sourcesContent":["<script>\nimport { Navigation } from 'swiper/modules';\nimport { Swiper, SwiperSlide } from 'swiper/vue';\nimport github from '@/services/github';\n\nimport \"swiper/css\";\nimport 'swiper/css/navigation';\n\nexport default {\n    name: 'meusProjetos',\n    components: {\n        Swiper, \n        SwiperSlide\n    },\n    data() {\n        return {\n            projetosArray: [],\n            avatar: ''\n\n        }\n    },\n    mounted() {\n\n        github.get(\"/repos\")\n        .then((resp) => {\n            this.projetosArray = resp.data;\n        })\n\n        github.get()\n        .then((resp) => {\n            this.avatar = resp.data.avatar_url\n        })\n    },\n\n    setup() {\n        return {\n            modules: [Navigation]\n        }\n    },\n\n}\n\n</script>\n\n\n\n<template>\n\n    <div id=\"projetos\">\n        <h1>Projetos</h1>\n        <swiper \n        :slides-per-view=\"1\" \n        :space-between=\"50\" \n        :navigation=\"true\"\n        :modules=\"modules\"\n        class=\"swiper\"\n        \n        >\n            <swiper-slide v-for=\"(SlideContent, index) in projetosArray\" :key=\"index\">\n                    <article class=\"container\">\n                        <section>\n                            <div class=\"projetos\">\n                                <div id=\"avatar\">\n                                    <a class=\"github-link\" :href=\"SlideContent.owner.html_url\" target=\"_blank\">\n                                        <img id=\"foto\" :src=\"avatar\">\n                                    </a>\n                                </div>\n                                <h2>{{ SlideContent.name }}</h2>\n                                <p>{{ SlideContent.description }}</p>\n                                <div id=\"stacks\">\n                                    <label><b>Stack:</b></label>\n                                    <p>