rc=\"../../../public/img/icons/avancar.svg\" id=\"voltar\" @click=\"voltarPagina\">    \n            <p>{{ pagina }} de {{ qtdPaginas }}</p>\n            <img src=\"../../../public/img/icons/avancar.svg\" id=\"avancar\" @click=\"avancarPagina\">\n        </div>\n    </div>\n</template>\n\n<style scoped>\n@import '@/style/global.css';\n@import 'animate.css';\n@import '@/style/animations.css';\n\ndiv {\n    height: 100%;\n    width: 100%;\n}\n\ninput {\n    background-color: var(--bege-bg);\n    background-image: url('../../../public/img/icons/lupa.svg');\n    background-position: 3% center;\n    background-repeat: no-repeat;\n    background-size: 10%;\n    border-radius: 5px;\n    border: none;\n    color: var(--branco);\n    font-size: 2rem;\n    height: 25px;\n    margin-left: 14px;\n    margin-top: 5%;\n    padding-left: 10%;\n    width: 90%;\n}\n\ninput:focus {\n    outline: none;\n}\n\n#avancar {\n    align-self: center;\n    background-color: var(--bege-bg);\n    border-radius: 5px;\n    margin: 0 14px;\n}\n\n#voltar {\n    align-self: center;\n    background-color: var(--bege-bg);\n    border-radius: 5px;\n    transform: scaleX(-1);\n    margin: 0 14px;\n}\n\n.paginacao {\n    align-items: center;\n    display: flex;\n    justify-content: center;\n}\n\n.paginacao img {\n    height: 15px;\n    width: 25px;\n}\n\n.paginacao p {\n    color: var(--branco);\n    font-size: 0.8rem;\n    text-align: center;\n}\n\n.header {\n    display: flex;\n}\n\n\n@media(min-width: 950px) {\n\n    input {\n        background-size: 5%;\n        height: 50px;\n        margin-bottom: 5%;\n    }\n\n    .paginacao img {\n        height: 30px;\n        width: 50px;\n    }\n}\n\n@media(min-width: 1490px) {\n\n    input {\n        border-radius: 15px;\n        font-size: 2rem;\n        height: 52px;\n        margin-right: 14px;\n        padding-left: 10%;\n        width: 90%;\n    }\n\n    input:focus {\n        outline: none;\n    }\n\n    #avancar {\n        align-self: center;\n        background-color: var(--bege-bg);\n        border-radius: 5px;\n        height: 29px;\n        margin: 0 14px;\n        width: 35px;\n    }\n\n    #voltar{\n        align-self: center;\n        background-color: var(--bege-bg);\n        border-radius: 5px;\n        height: 29px;\n        margin: 0 14px;\n        transform: scaleX(-1);\n        width: 35px;\n    }   \n    \n    .paginacao {\n        align-items: center;\n        display: flex;\n        justify-content: center;\n        margin: 0;\n    }\n\n    .paginacao p {\n        font-size: 1rem;\n    }\n}\n\n</style>"],"mappings":"AACI,eAAe;EACXA,IAAI,EAAE,UAAU;EAChBC,KAAK,EAAE;IACHC,UAAU,EAAEC,MAAM;IAClBC,MAAM,EAAED,MAAM;IACdE,aAAa,EAAE;MACXC,IAAI,EAAEC,QAAQ;MACdC,QAAQ,EAAE;IACd,CAAC;IACDC,YAAY,EAAE;MACVH,IAAI,EAAEC,QAAQ;MACdC,QAAQ,EAAE;IACd;EACJ,CAAC;EACDE,IAAIA,CAAA,EAAG;IACH,OAAO;MACHC,cAAc,EAAE;IACpB;EACJ,CAAC;EACDC,OAAO,EAAC;IACJC,WAAW,EAAE,SAAAA,CAASC,CAAC,EAAC;MACpB,IAAI,CAACC,KAAK,CAAC,aAAa,EAAED,CAAC,CAACE,MAAM,CAACC,KAAK;IAC5C,CAAC;IACDC,WAAW,EAAE,SAAAA,CAAA,EAAW;MACpBC,QAAQ,CAACC,aAAa,CAAC,QAAQ,CAAC,CAACH,KAAI,GAAI,EAAE;MAC3C,IAAI,CAACN,cAAa,GAAI,EAAE;IAC5B;EACJ;AACJ"},"metadata":{},"sourceType":"module","externalDependencies":[]}