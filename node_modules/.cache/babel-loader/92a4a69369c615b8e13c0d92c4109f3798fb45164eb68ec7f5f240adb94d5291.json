n        return {\n            exibirNasa: true,\n            exibirRN: false,\n//            exibirMusica: false\n        }\n    },\n    methods: {\n\n        mostrarNasa: function () {\n\n            if (this.exibirRN === true) {\n                this.exibirRN = false\n            }\n//            if (this.exibirMusica === true) {\n//                this.exibirMusica = false\n//            }\n\n            this.exibirNasa = true\n        },\n\n        mostrarRN: function () {\n\n            if (this.exibirNasa === true) {\n                this.exibirNasa = false\n            }\n\n//            if (this.exibirMusica === true) {\n//                this.exibirMusica = false\n//            }\n\n            this.exibirRN = true\n        },\n\n//        mostrarMusicas: function () {\n\n//            if (this.exibirNasa === true) {\n//                this.exibirNasa = false\n//            } \n\n//            if (this.exibirRN === true) {\n//                this.exibirRN = false\n//            }\n//            this.exibirMusica = true\n//        }\n    },\n}\n</script>\n\n<template>\n    <h1 id=\"api\">Consumindo APIs</h1>\n    <div>\n        <div id=\"display\">\n            <div class=\"buttons\">\n                <a @click=\"mostrarNasa()\">API da NASA</a>\n                <a id=\"rm\" @click=\"mostrarRN()\">Rick and Morty</a>\n<!--               <p id=\"musicas\" @click=\"mostrarMusicas()\"></p> -->\n            </div>\n            <div id=\"sidebar\"></div>\n            <div id=\"panel\">\n                <div v-if=\"exibirNasa\" id=\"nasa\">\n                    <apiNasa :exibirNasa=\"exibirNasa\" />\n                </div>\n                <div v-if=\"exibirRN\" id=\"rickandmorty\">\n                    <indexPageRn />\n                </div>\n                <!-- <div v-if=\"exibirMusica\" id=\"musicas-autorais\">\n                    <musicasAutorais />\n                </div> -->\n            </div>\n        </div>\n    </div>\n</template>\n\n<style scoped>\n\n@import '@/style/global.css';\n@import 'animate.css';\n@import '@/style/animations.css';\n\na:hover {\n    cursor: pointer;\n}\n\ndiv {\n    align-items: center;\n    display: flex;\n    justify-content: center;\n\n} \n\nh1 {\n    color: var(--branco);\n    font-size: 1.5rem;\n    margin: 5% 0 0 0 ;\n    text-align: center;\n}\n\n#display {\n    background-color: var(--verde-escuro);\n    border-radius: 5px;\n    height: 342px;\n    margin: 2% 0;\n    width: 430px;\n}\n\n#musicas {\n    background-color: var(--verde-escuro);\n    background-image: url(../../public/img/icons/music.svg);\n    background-position: center;\n    background-repeat: no-repeat;\n    background-size: 60%;\n    border: solid 3.5px var(--bege-bg);\n    border-radius: 100px;\n    cursor: pointer;\n    height: 50px;\n    justify-self: flex-end;\n    margin-top: 120%;\n    width: 50px;\n}\n\n#musicas-autorais {\n    height: 100%;\n    width: 100%;\n    overflow: auto;\n}\n\n#nasa {\n    display: flex;\n    align-items: flex-start;\n    height: 100%;\n    margin-top: 15%;\n    width: 100%;\n}\n\n#panel {\n    align-items: flex-start;\n    background-color: #3b5005;\n    border: solid 5px #2e3f05;\n    border-radius: 5px;\n    height: 80%;\n    justify-content: center;\n    margin-left: 5%;\n    margin-right: -15%;\n    width: 50%;\n}\n\n#rickandmorty {\n    align-items: flex-start;\n    display: flex;\n    justify-content: flex-start;\n    height: 100%;\n    width: 100%;\n}\n\n#rm {\n    font-size: 8px;\n}\n\n#sidebar {\n    border: solid 1px #3b5005;\n    height: 95%;\n    margin-left: 5%;\n    opacity: 0.8;\n}\n\n.buttons {\n    align-items: flex-start;\n    display: flex;\n    flex-direction: column;\n    margin-left: -15%;\n    margin-top: -50%;\n\n}\n\n.buttons a {\n    background-color: var(--bege-bg);\n    border: solid 2px #EAD05E;\n    border-radius: 5px;\n    color: var(--branco);\n    font-size: 10px;\n    font-weight: bold;\n    height: 18px;\n    margin-top: 30%;\n    margin-left: -10%;\n    text-align: center;\n    width: 84px;\n}\n\n.buttons a:hover {\n    animation: jello 1s;\n}\n\n\n\n@media (min-width: 950px) {\n\n    #display {\n        border-radius: 15px;\n        height: 605px;\n        width: 822px;\n    }\n\n    #panel {\n        border-radius: 15px;\n        height: 512px;\n        margin-left: 14%;\n        width: 520px;\n    }\n\n\n    #sidebar {\n        margin-left: 1%;\n        margin-right: -5%;\n\n    }\n\n    #musicas {\n        height: 80px;\n        margin-left: 5%;\n        width: 80px;\n    }\n\n    #rm {\n        font-size: 0.8rem;\n        margin-bottom: 150%;\n        text-align: center;\n    }\n\n    .buttons {\n        margin-top: -25%;\n    }\n\n    .buttons a {\n        font-size: 0.8rem;\n        height: 25px;\n        margin-top: 30%;\n        margin-left: -10%;\n        text-align: center;\n        width: 138px;\n    }\n\n\n}\n\n@media (min-width: 1490px) {\n\n    h1 {\n        font-size: 3rem;\n    }\n    \n    #display {\n        border-radius: 25px;\n        height: 1205px;\n        width: 1445px;\n    }\n\n\n    #panel {\n        border-radius: 25px;\n        height: 1145px;\n        margin: 0%;\n        width: 942px;\n    }\n\n    #sidebar {\n        margin: 0% 3%;\n    }\n\n    .buttons{ \n        margin-left: 2%;\n        margin-right: 0%;\n    }\n\n    .buttons a {\n        border-radius: 16px;\n        font-size: 2rem;\n        height: 52px;\n        width: 329px;\n    }\n\n    #musicas {\n        border: solid 10px var(--bege-bg);\n        height: 140px;\n        width: 140px;\n        margin-top: 0%;\n    }\n\n    #rm {\n        font-size: 2rem;\n    }\n\n}\n\n</style>\n"],"mappings":"AACA;AACA,OAAOA,OAAM,MAAO,0BAA0B;AAC9C,OAAOC,WAAU,MAAO,2CAA2C;AAEnE,eAAe;EACXC,IAAI,EAAE,gBAAgB;EACtBC,UAAU,EAAE;IACRH,OAAO;IACPC;IACR;EACI,CAAC;EACDG,IAAGA,CAAA,EAAK;IACJ,OAAO;MACHC,UAAU,EAAE,IAAI;MAChBC,QAAQ,EAAE;MACtB;IACQ;EACJ,CAAC;EACDC,OAAO,EAAE;IAELC,WAAW,EAAE,SAAAA,CAAA,EAAY;MAErB,IAAI,IAAI,CAACF,QAAO,KAAM,IAAI,EA