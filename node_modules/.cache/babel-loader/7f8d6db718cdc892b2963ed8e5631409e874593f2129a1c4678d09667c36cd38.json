verflow: auto;\n    position: absolute;\n    top: 50;\n    width: 210px;\n    z-index: 100;\n    animation: .5s;\n}\n\n#nome {\n    animation-delay: 0.25s;\n}\n\n#personagemContainer {\n    display: flex;\n    height: 90px;\n    margin-bottom: 20%;\n    padding: 5% 10%;\n    width: 90px;\n}\n\n#primeiraColuna {\n    display: flex;\n    flex-direction: column;\n    margin: 5% 15%;\n}\n\n#segundaColuna {\n    display: flex;\n    flex-direction: column;\n    margin: 0 1%;\n}\n\n\n\n    ::-webkit-scrollbar {\n        width: 5px;\n    }\n\n    ::-webkit-scrollbar-track {\n        display: none;\n    }\n\n    ::-webkit-scrollbar-thumb {\n        background: var(--branco);\n        border-radius: 2px;\n\n    }\n\n@media (min-width: 950px) {\n\n    a {\n        font-size: 1rem;\n        white-space: nowrap;\n    }\n\n    p {\n        font-size: 1.5rem;\n    }\n\n    #episodios {\n        width: 45px;\n    }\n\n    #personagemContainer {\n        height: 212px;\n        width: 256px;\n    }\n\n    #primeiraColuna {\n        margin-right: 25%;\n        margin-top: -12px;\n    }\n\n    .episodiosCont {\n        height: 720px;\n        width: 510px;\n    }\n}\n\n\n@media (min-width: 1490px) {\n\n    a{\n        font-size: 1rem;\n        white-space: nowrap;\n    }\n\n    img {\n        border: solid 7px var(--bege-bg);\n        border-radius: 5px;\n    }\n\n    p {\n        color: var(--branco);\n        font-size: 1.5rem;\n        margin: 5%10%;\n        white-space: nowrap;\n    }\n\n    #episodios {\n        border: solid 2px var(--bege-bg);\n        border-radius: 5px;\n        width: 168px;\n    }\n\n    #erro {\n        color: red;\n        display: none;\n        font-size: 1rem;\n    }\n\n    #localidade {\n        white-space: pre-wrap;\n    }\n\n    #nome {\n        animation-delay: 0.25s;\n        white-space: pre-wrap;\n    }\n\n    #origem {\n        animation-delay: 0.5s;\n        white-space: pre-wrap;\n    }\n\n    #personagemContainer {\n        height: 290px;\n        padding: 5% 10%;\n        width: 325px;\n    }\n\n    #primeiraColuna {\n        display: flex;\n        flex-direction: column;\n        margin: -15px 15%;\n    }\n\n    #segundaColuna {\n        display: flex;\n        flex-direction: column;\n        margin: -15px 15%;\n    }\n\n    .episodiosCont {\n        height: 560px;\n        width: 440px;\n    }\n\n    .genero {\n        animation-delay: 0.25s;\n    }\n\n    .status {\n        animation-delay: 0.5s;\n    }\n}\n</style>\n@/services/rickAndMorty\n"],"mappings":";;gEAuGYA,mBAAA,CAA2D;EAAxDC,EAAE,EAAC,MAAM;EAACC,KAAK,EAAC;;;EAvG/BC,GAAA;EA0GiCD,KAAK,EAAC;;mBA1GvC;;EA+GaD,EAAE,EAAC;AAAgB;;EACjBC,KAAK,EAAC,mCAAmC;EAACD,EAAE,EAAC;;;EAC7CC,KAAK,EAAC;AAA0C;;EAChDA,KAAK,EAAC;AAAqD;;EAAgBD,EAAE,EAAC;AAAY;;EAE5FA,EAAE,EAAC;AAAe;;EAChBC,KAAK,EAAC;AAA0C;;EAChDA,KAAK,EAAC,mCAAmC;EAACD,EAAE,EAAC;;oBAtH5D;;;;uBAAAG,mBAAA,CAAAC,SAAA,SAoGIL,mBAAA,CAKM,cAJFA,mBAAA,CAGS,iBAFLM,YAAA,CAAwJC,uBAAA;IAAzIC,aAAW,EAAEC,QAAA,CAAAC,mBAAmB;IAAGC,MAAM,EAAEC,KAAA,CAAAD,MAAM;IAAGE,UAAU,EAAED,KAAA,CAAAC,UAAU;IAAGC,YAAY,EAAEL,QAAA,CAAAK,YAAY;IAAGC,aAAa,EAAEN,QAAA,CAAAM;uGACxIC,UAA2D,C,KAGxDJ,KAAA,CAAAK,gBAAgB,I,cAA3Bb,mBAAA,CAEM,OAFNc,UAEM,GADFZ,YAAA,CAA8Ga,yBAAA;IAA7FC,OAAO,EAAER,KAAA,CAAAQ,OAAO;IAAGC,gBAAgB,EAAET,KAAA,CAAAS,gBAAgB;IAAGC,gBAAgB,EAAEb,QAAA,CAAAa;oFA3GnGC,mBAAA,iB,kBA6GInB,mBAAA,CAYMC,SAAA,QAzHVmB,WAAA,CA6GiDf,QAAA,CAAAgB,cAAc,EAAtBC,IAAI;yBAAzCtB,mBAAA,CAYM;MAZDH,EAAE,EAAC,qBAAqB;MAAiCE,GAAG,EAAEuB,IAAI,CAACzB;QACpED,mBAAA,CAAuE;MAAjE2B,GAAG,EAAED,IAAI,CAACE,KAAK;MAAE1B,KAAK,EAAC;4BA9GrC2B,UAAA,GA+GQ7B,mBAAA,CAIM,OAJN8B,UAIM,GAHF9B,mBAAA,CAAuF,KAAvF+B,UAAuF,GAhHnGC,gBAAA,CAgHmE,QAAM,GAAAhC,mBAAA,CAAsB,WAAAiC,gBAAA,CAAhBP,IAAI,CAACQ,IAAI,iB,GAC5ElC,mBAAA,CAAwF,KAAxFmC,UAAwF,GAjHpGH,gBAAA,CAiHgE,UAAQ,GAAAhC,mBAAA,CAAwB,WAAAiC,gBAAA,CAAlBP,IAAI,CAACU,MAAM,iB,GAC7EpC,mBAAA,CAA8H,KAA9HqC,UAA8H,GAlH1IL,gBAAA,CAkH2E,cAAY,GAAAhC,mBAAA,CAA+C,KAA/CsC,UAA+C,EAAAL,gBAAA,CAAzBP,IAAI,CAACa,QAAQ,CAACL,IAAI,iB,KAEvHlC,mBAAA,CAIM,OA