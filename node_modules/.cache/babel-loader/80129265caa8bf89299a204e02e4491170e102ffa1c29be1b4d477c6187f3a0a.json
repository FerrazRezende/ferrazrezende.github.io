n    ::-webkit-scrollbar-thumb {\n        background: var(--branco);\n        border-radius: 2px;\n    }\n\n\n@media (min-width: 950px) {\n\n    \n    a {\n        height: 100%;\n    }\n\n    header {\n        height: 40%;\n        width: 90%;\n    }\n\n    h1 {\n        color: var(--branco);\n        font-size: 1.5rem;\n        margin: 2% 0;\n        text-align: center;\n    }\n\n    p {\n        font-size: 1rem;\n    }\n\n    h2 {\n        font-size: 1rem;\n        margin-right: 30%;\n    }\n\n    div {\n        border-radius: 10px;\n    }\n\n    #thumb {\n        border: 4px solid var(--verde-escuro);\n        border-radius: 50%;\n        height: 150px;\n        width: 120px;\n    }\n\n\n    #player {\n        align-items: space-between;\n        background-color: var(--bege-bg);\n        border-radius: 10px;\n        display: flex;\n        justify-content: center;\n        margin: 5%;\n        width: 510px;\n    }\n\n    #play {\n        height: 45px;\n        margin: 0 20%;\n        width: 45px;\n\n    }\n}\n\n@media (min-width: 1490px) {\n    \n    h1 {\n        color: var(--branco);\n        font-size: 2rem;\n        margin: 2% 0;\n        text-align: center;\n    }\n\n    h2 {\n        margin-left: -30%;\n        white-space: nowrap;\n    }\n\n    div {\n        border-radius: 25px;\n    }\n\n    header {\n        height: 50%;\n        width: 90%;\n    }\n\n    #tempo {\n        align-items: center;\n        display: flex;\n        flex-direction: row;\n        justify-content: center;\n    }\n\n    #player-buttons {\n        margin-top: -15%;\n    }\n\n    #thumb {\n        border: 10px solid var(--verde-escuro);\n        border-radius: 50%;\n        height: 250px;\n        width: 250px;\n    }\n\n    #volume-button {\n        align-items: center;\n        display: flex;\n        flex-direction: column;\n        justify-content: center;\n        margin-top: 5%;\n        height: 25px;\n    }\n\n    #volume-control::-webkit-slider-thumb {\n        appearance